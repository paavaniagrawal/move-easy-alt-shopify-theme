<!-- ── Product gallery + option selection JS ── -->
<script>
  (function () {
    // Thumbnail gallery
    var mainImg = document.getElementById('product-main-image');
    var thumbBtns = document.querySelectorAll('.thumb-btn');

    thumbBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        thumbBtns.forEach(function (b) {
          b.classList.remove('border-primary-500');
          b.classList.add('border-[rgba(18,18,18,0.15)]');
        });
        btn.classList.add('border-primary-500');
        btn.classList.remove('border-[rgba(18,18,18,0.15)]');
        mainImg.classList.add('loading');
        setTimeout(function () {
          mainImg.src = btn.dataset.src;
          mainImg.classList.remove('loading');
        }, 150);
      });
    });

    // Purchase option highlight
    var options = document.querySelectorAll('.purchase-option');
    options.forEach(function (label) {
      label.addEventListener('click', function () {
        options.forEach(function (l) {
          l.classList.remove('border-primary-500', 'bg-primary-50');
          l.classList.add('border-[rgba(18,18,18,0.15)]', 'bg-white');
          var dot = l.querySelector('.option-dot');
          if (dot) { dot.classList.remove('bg-primary-500'); dot.classList.add('bg-transparent'); }
          var radio = l.querySelector('input[type="radio"]');
          var circle = l.querySelector('.w-5');
          if (circle) { circle.classList.remove('border-primary-500'); circle.classList.add('border-[#ccc]'); }
        });
        label.classList.add('border-primary-500', 'bg-primary-50');
        label.classList.remove('border-[rgba(18,18,18,0.15)]', 'bg-white');
        var dot = label.querySelector('.option-dot');
        if (dot) { dot.classList.add('bg-primary-500'); dot.classList.remove('bg-transparent'); }
        var circle = label.querySelector('.w-5');
        if (circle) { circle.classList.add('border-primary-500'); circle.classList.remove('border-[#ccc]'); }
      });
    });
  })();
</script>

