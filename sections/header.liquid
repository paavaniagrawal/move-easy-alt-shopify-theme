<header class="bg-beige-500 h-20 flex items-center justify-between px-16 sticky top-0 z-50 w-full">
  <!-- Logo -->
  <a href="{{ routes.root_url }}" class="flex items-center">
    {%- if section.settings.logo != blank -%}
      <img
        src="{{ section.settings.logo | image_url: width: 220 }}"
        alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
        class="h-11 w-auto object-contain"
        loading="eager"
      >
    {%- else -%}
      <span class="font-sans font-bold text-xl text-primary-500">{{ shop.name }}</span>
    {%- endif -%}
  </a>

  <!-- Review badge -->
  {% render 'review-badge' %}

  <!-- Shop Now CTA -->
  <a href="/collections/all" class="bg-primary-500 text-white font-sans font-medium text-base px-5 py-3 rounded-pill hover:bg-primary-700 transition-colors">
    Shop Now
  </a>
</header>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    }
  ]
}
{% endschema %}
