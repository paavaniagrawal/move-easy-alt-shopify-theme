<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {{ content_for_header }}

    <!-- Google Fonts: DM Sans (body) + Lora (headings) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">

    <!-- Tailwind CSS Play CDN (development) — replace with compiled CSS for production -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['DM Sans', 'sans-serif'],
              serif: ['Lora', 'serif'],
            },
            colors: {
              primary: {
                50:  '#ebf4ff',
                100: '#dbeafe',
                300: '#93c5fd',
                500: '#1b61bb',
                700: '#1e40af',
              },
              beige: {
                50:  '#fdfdfc',
                500: '#f4f4ed',
                600: '#e8e8e0',
              },
              'brand-green': '#39ae5e',
              grey: {
                200: '#e5e7eb',
                900: '#323334',
              },
              'blue-light': '#ebf4ff',
            },
            borderRadius: {
              card: '18px',
              pill: '37.5px',
            },
          }
        }
      }
    </script>

    {{ 'base.css' | asset_url | stylesheet_tag }}
  </head>

  <body class="bg-beige-50 font-sans">
    {% section 'header' %}

    <main id="MainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <script src="{{ 'base.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
