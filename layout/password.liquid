<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ shop.name }} — Coming Soon</title>

    {{ content_for_header }}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Lora:ital,wght@0,400;0,500;0,600;0,700&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['DM Sans', 'sans-serif'],
              serif: ['Lora', 'serif'],
            },
            colors: {
              primary: { 500: '#1b61bb', 700: '#1e40af' },
              beige:   { 50: '#fdfdfc', 500: '#f4f4ed' },
              grey:    { 200: '#e5e7eb', 900: '#323334' },
            },
            borderRadius: { pill: '37.5px' },
          }
        }
      }
    </script>
  </head>

  <body class="bg-beige-50 font-sans">
    <div class="min-h-screen flex items-center justify-center px-8 py-16">
      <div class="flex flex-col items-center gap-8 text-center max-w-md w-full">
        <span class="font-sans font-bold text-2xl text-primary-500">{{ shop.name }}</span>
        <h1 class="font-serif font-semibold text-4xl leading-tight text-grey-900">Opening Soon</h1>
        <p class="font-sans text-lg text-grey-900">We&rsquo;re putting the finishing touches on something great. Enter the password to get a sneak peek.</p>

        {% form 'storefront_password' %}
          {%- if form.errors -%}
            <p class="font-sans text-sm text-red-600">{{ form.errors | default_errors }}</p>
          {%- endif -%}
          <div class="flex flex-col gap-4 w-full mt-2">
            <input
              type="password"
              name="password"
              placeholder="Password"
              class="border border-grey-200 rounded-pill px-6 py-4 font-sans text-lg text-grey-900 outline-none focus:border-primary-500 w-full"
              aria-label="Password"
            >
            <button
              type="submit"
              class="bg-primary-500 text-white font-sans font-medium text-lg px-8 py-4 rounded-pill hover:bg-primary-700 transition-colors w-full"
            >
              Enter Store
            </button>
          </div>
        {% endform %}
      </div>
    </div>
  </body>
</html>
